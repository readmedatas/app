{
  "targetUrl": "https://sundhagold.com/Login.html",
  "jsCode": "(function(){function login(){try{var username=document.getElementById('name');var password=document.getElementById('mobile');var loginBtn=document.getElementById('btnLogin');if(username&&password&&loginBtn){username.value='57774';password.value='8109';username.dispatchEvent(new Event('input',{bubbles:true}));password.dispatchEvent(new Event('input',{bubbles:true}));loginBtn.click();window.ReactNativeWebView.postMessage(JSON.stringify({status:'LOGIN_CLICKED'}));}}catch(e){window.ReactNativeWebView.postMessage(JSON.stringify({error:e.message}));}}function scrape(){try{var data={products:[]};document.querySelectorAll('#gvData table table table').forEach(function(card){var spans=card.querySelectorAll('span');if(spans.length>=4){var label=spans[0].innerText.trim().toUpperCase();if(label==='GOLD'){data.gold=spans[1].innerText.trim();data.goldLow=spans[2].innerText.trim();data.goldHigh=spans[3].innerText.trim();}if(label==='SILVER'){data.silver=spans[1].innerText.trim();data.silverLow=spans[2].innerText.trim();data.silverHigh=spans[3].innerText.trim();}if(label==='USDINR'){data.inr=spans[1].innerText.trim();data.inrLow=spans[2].innerText.trim();data.inrHigh=spans[3].innerText.trim();}}});document.querySelectorAll('#gvData_Trending .buy_sell_label').forEach(function(label){var row=label.closest('tr');if(!row)return;var cells=row.querySelectorAll('td');if(cells.length>=5){data.products.push({name:cells[0].innerText.trim(),buy:cells[1].innerText.trim(),sell:cells[2].innerText.trim(),high:cells[3].innerText.trim(),low:cells[4].innerText.trim()});}});if(data.products.length>0){window.ReactNativeWebView.postMessage(JSON.stringify(data));}}catch(e){window.ReactNativeWebView.postMessage(JSON.stringify({error:e.message}));}}setTimeout(login,3000);setTimeout(function(){scrape();setInterval(scrape,3000);},10000);})();true;"
}
