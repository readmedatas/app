{
  "targetUrl": "https://safaribullions.com/",
  "jsCode": "(function(){function scrape(){try{const data={};const labels=document.querySelectorAll('.Trending_top3_label');const values=document.querySelectorAll('.GDINRRates span');labels.forEach((label,index)=>{const text=label.textContent.trim().toUpperCase();const value=values[index]?.textContent?.trim();if(!value)return;if(text.includes('GOLD($)'))data.gold=value;else if(text==='INR')data.inr=value;else if(text.includes('SILVER'))data.silver=value;});console.log('SCRAPED DATA',data);window.ReactNativeWebView.postMessage(JSON.stringify(data));}catch(e){window.ReactNativeWebView.postMessage(JSON.stringify({error:String(e)}));}}setTimeout(scrape,3000);setInterval(scrape,3000);})();true;"
}
