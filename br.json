{
  "targetUrl": "https://slnbullion.in/",
  "jsCode": "(function(){function scrape(){try{var data={};document.querySelectorAll('#gvData .goldd').forEach(function(box){var title=box.querySelector('tr:first-child td');var value=box.querySelector('.top5span');if(!title||!value)return;var name=title.innerText.trim().toUpperCase();var rate=value.innerText.trim();if(name.indexOf('GOLD')!==-1)data.gold=rate;else if(name.indexOf('SILVER')!==-1)data.silver=rate;else if(name.indexOf('INR')!==-1)data.inr=rate;});document.querySelectorAll('#gvData tr').forEach(function(row){var label=row.querySelector('.buy_sell_label');if(!label)return;var text=label.innerText.trim().toUpperCase();var spans=row.querySelectorAll('span');if(text==='INDIA GOLD'&&spans.length>0){data.goldMcx=spans[0].innerText.trim();}if(text==='INDIA SILVER'&&spans.length>0){data.silverMcx=spans[0].innerText.trim();}});if(Object.keys(data).length){window.ReactNativeWebView.postMessage(JSON.stringify(data));}}catch(e){window.ReactNativeWebView.postMessage(JSON.stringify({error:e.message}));}}setTimeout(scrape,5000);setInterval(scrape,3000);})();true;"
}
