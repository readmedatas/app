{
  "targetUrl": "https://safaribullions.com/",
  "jsCode":(function() {
  function getText(el) {
    return el ? el.innerText.trim() : "";
  }

  function scrape() {
    try {
      const data = {};

      // ==========================
      // GOLD TAB
      // ==========================

      const goldSummary = document.querySelector("#gvData");

      if (goldSummary) {
        const labels = goldSummary.querySelectorAll(".Trending_top3_label");

        labels.forEach((label) => {
          const name = label.innerText.trim().toUpperCase();

          const value =
            label.parentElement.nextElementSibling?.innerText.trim() || "";

          if (name.includes("GOLD($)")) {
            data.gold = value;
          }

          if (name === "INR") {
            data.inr = value;
          }

          if (name.includes("GOLD COSTING")) {
            data.goldMcx = value;
          }
        });
      }

      // ==========================
      // SILVER TAB
      // ==========================

      const silverSummary = document.querySelector("#gvData_Silver");

      if (silverSummary) {
        const labels = silverSummary.querySelectorAll(".Trending_top3_label");

        labels.forEach((label) => {
          const name = label.innerText.trim().toUpperCase();

          const value =
            label.parentElement.nextElementSibling?.innerText.trim() || "";

          if (name === "SILVER") {
            data.silver = value;
          }
        });
      }

      // ==========================
      // SILVER MCX
      // ==========================

      const silverRows = document.querySelectorAll(
        "#gvData_Trending_Silver .Script_Nameee"
      );

      silverRows.forEach((row) => {
        const title = row.innerText.trim().toUpperCase();

        if (title.includes("SILVER COSTING")) {
          const tr = row.closest("tr");

          const spans = tr.querySelectorAll("span");

          if (spans.length > 0) {
            const rate =
              spans[spans.length - 1].innerText.trim();

            data.silverMcx = rate;
          }
        }
      });

      console.log("SCRAPED DATA", data);

      if (Object.keys(data).length > 0) {
        window.ReactNativeWebView.postMessage(
          JSON.stringify(data)
        );
      }

    } catch (e) {
      window.ReactNativeWebView.postMessage(
        JSON.stringify({
          error: e.message
        })
      );
    }
  }

  setTimeout(scrape, 5000);
  setInterval(scrape, 3000);
})();
true;
}
